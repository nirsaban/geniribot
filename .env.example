# ---- Database ----
DATABASE_URL="postgresql://kesher:kesher@localhost:55432/kesher?schema=public"

# ---- Redis (cache, queues, sessions) ----
REDIS_URL="redis://localhost:6379"

# ---- Auth ----
# 32+ char random secret. Generate: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret-value"
# Stable key so Next.js server actions survive restarts/redeploys. openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="change-me-openssl-rand-base64-32"
# Encryption key for secrets at rest (WhatsApp creds, Google tokens). 32 bytes base64.
SECRETS_KEY="change-me-openssl-rand-base64-32"

# ---- Gateway (WhatsApp service) ----
GATEWAY_URL="http://localhost:4020"
# Shared token so web/worker can call the gateway's internal API.
GATEWAY_INTERNAL_TOKEN="change-me-internal-token"

# ---- Web ----
WEB_PORT=4000
NEXT_PUBLIC_APP_NAME="Kesher"
# Public origin (used to build Grow success/cancel URLs)
PUBLIC_BASE_URL="https://wabot.miltech.cloud"

# ---- Billing: Grow (Israeli payments, formerly Meshulam) ----
# Per-tenant Grow keys (page code / user id / api key) are pasted in the app UI
# and stored ENCRYPTED — they are NOT env vars. This only toggles sandbox mode.
GROW_SANDBOX=0

# ---- Google Calendar (Phase 5, optional) ----
# Create an OAuth 2.0 Client (type: Web) in Google Cloud Console, enable the
# Google Calendar API, and add the redirect URI below to the client. Then the
# dashboard Settings page shows "Connect Google Calendar". Without these, the
# feature is hidden and booking/reminders still work (no calendar sync).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://wabot.miltech.cloud/api/integrations/google/callback"
