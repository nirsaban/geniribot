# ---- Database ----
DATABASE_URL="postgresql://kesher:kesher@localhost:55432/kesher?schema=public"

# ---- Redis (cache, queues, sessions) ----
REDIS_URL="redis://localhost:6379"

# ---- Auth ----
# 32+ char random secret. Generate: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret-value"
# Encryption key for secrets at rest (WhatsApp creds, Google tokens). 32 bytes base64.
SECRETS_KEY="change-me-openssl-rand-base64-32"

# ---- Gateway (WhatsApp service) ----
GATEWAY_URL="http://localhost:4020"
# Shared token so web/worker can call the gateway's internal API.
GATEWAY_INTERNAL_TOKEN="change-me-internal-token"

# ---- Web ----
WEB_PORT=4000
NEXT_PUBLIC_APP_NAME="Kesher"

# ---- Google Calendar (Phase 5, optional now) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/integrations/google/callback"
