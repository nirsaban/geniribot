// Kesher — data model. See docs/DATA-MODEL.md for rationale.
// Every domain table carries organizationId for tenant isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Tenancy & auth ----------
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  connections   WhatsAppConnection[]
  flows         Flow[]
  contacts      Contact[]
  conversations Conversation[]
  appointments  Appointment[]
  availability  AvailabilityRule[]
  calendarLinks CalendarIntegration[]
  secrets       Secret[]
  invites       Invite[]
  leadNotes     LeadNote[]
  activities    LeadActivity[]
  onboardedAt   DateTime?
  calcomLink    String?
}

// Encrypted per-tenant secrets (e.g. Grow payment API keys). Values are stored
// AES-256-GCM encrypted; never returned to the client in plaintext.
model Secret {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  valueEnc       String
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  passwordHash   String
  name           String?
  role           Role     @default(AGENT)
  isSuperAdmin   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownedContacts  Contact[]      @relation("ContactOwner")
  leadNotes      LeadNote[]
  leadActivities LeadActivity[]
  sentInvites    Invite[]       @relation("InviteSender")

  @@index([organizationId])
}

enum Role {
  OWNER
  ADMIN
  AGENT
}

/**
 * A pending teammate invitation. The raw token is shown to the inviter exactly
 * once and never stored — only its SHA-256 hash — so a database leak cannot be
 * replayed into account creation.
 */
model Invite {
  id             String    @id @default(cuid())
  organizationId String
  email          String?
  role           Role      @default(AGENT)
  tokenHash      String    @unique
  invitedById    String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InviteSender", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

enum Plan {
  FREE
  STARTER
  PRO
}

// ---------- WhatsApp ----------
model WhatsAppConnection {
  id             String   @id @default(cuid())
  organizationId String
  label          String
  phoneNumber    String?
  provider       String   @default("baileys")
  status         WaStatus @default(PENDING)
  authState      Json?
  defaultFlowId  String?
  // Cloud API / Embedded Signup metadata (null for Baileys connections).
  wabaId             String?
  displayPhoneNumber String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum WaStatus {
  PENDING
  QR
  CONNECTED
  DISCONNECTED
  LOGGED_OUT
}

// ---------- Flows ----------
model Flow {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  version        Int      @default(1)
  isActive       Boolean  @default(false)
  definition     Json
  /**
   * The canonical set of fields this scenario collects, derived from
   * `definition` on every save: [{ key, label, expect, choices?, order }].
   *
   * Without this the field set is emergent — just whatever `field` strings the
   * builder happened to type — so the CRM cannot know a column exists until
   * some lead has filled it, cannot label it, and cannot tell a date from a
   * number. Persisting it makes the fields a fixed contract for the campaign.
   */
  fieldSchema    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ---------- Contacts / leads ----------
model Contact {
  id             String   @id @default(cuid())
  organizationId String
  phone          String
  /**
   * Full WhatsApp JID this contact messages us from. For LID ("hidden number")
   * senders `phone` holds an opaque id rather than a real number, so this is the
   * only routable address we have — outbound must prefer it.
   */
  waJid          String?
  name           String?
  fields         Json       @default("{}")
  tags           String[]   @default([])
  /** Where this lead sits in the sales pipeline. Advanced by agents, not the bot. */
  status         LeadStatus @default(NEW)
  /** The agent responsible for this lead. Null = unassigned. */
  ownerUserId    String?
  /** Name of the flow/scenario that first engaged this lead (null = just an inbound msg). */
  source         String?
  /**
   * Stable reference to that scenario. `source` is a NAME and so breaks on
   * rename; this is what the CRM resolves the field schema through.
   */
  sourceFlowId   String?
  /**
   * What the agent recorded after the sales call — written by a human in the
   * dashboard, never generated. Separate from `notes` because every lead has at
   * most one call outcome, and it is what the list view surfaces.
   */
  callSummary     String?
  callSummaryAt   DateTime?
  callSummaryById String?
  /** Last inbound/outbound WhatsApp activity — drives "stale lead" surfacing. */
  lastContactedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner         User?          @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  appointments  Appointment[]
  notes         LeadNote[]
  activities    LeadActivity[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, ownerUserId])
  @@index([organizationId, createdAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  MEETING_SET
  WON
  LOST
}

/** Free-text notes an agent adds to a lead over time. */
model LeadNote {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String
  userId         String?
  body           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([contactId, createdAt])
}

/**
 * Append-only audit of everything that happened to a lead. This is what makes
 * handing a lead between agents work: the next person can see who did what and
 * when, rather than inferring it from the current field values.
 */
model LeadActivity {
  id             String       @id @default(cuid())
  organizationId String
  contactId      String
  /** Null = the system/bot acted, not a person. */
  userId         String?
  kind           ActivityKind
  /** Previous → new value for transitions (status, owner). Free-form by kind. */
  fromValue      String?
  toValue        String?
  meta           Json?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([contactId, createdAt])
}

enum ActivityKind {
  LEAD_CREATED
  STATUS_CHANGED
  OWNER_ASSIGNED
  NOTE_ADDED
  SUMMARY_SAVED
  TAGS_CHANGED
  APPOINTMENT_BOOKED
  CONVERSATION_COMPLETED
}

// ---------- Conversations (flow-run state) ----------
model Conversation {
  id             String      @id @default(cuid())
  organizationId String
  contactId      String
  connectionId   String
  flowId         String?
  currentNodeId  String?
  state          Json        @default("{}")
  status         ConvoStatus @default(ACTIVE)
  lastMessageAt  DateTime    @default(now())
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([organizationId])
  @@index([contactId])
}

enum ConvoStatus {
  ACTIVE
  COMPLETED
  HANDOFF
  ABANDONED
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  direction      Direction
  body           String
  raw            Json?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum Direction {
  IN
  OUT
}

// ---------- Scheduling ----------
model AvailabilityRule {
  id             String  @id @default(cuid())
  organizationId String
  userId         String?
  weekday        Int
  startMinute    Int
  endMinute      Int
  slotMinutes    Int     @default(30)
  bufferMinutes  Int     @default(0)
  timezone       String  @default("Asia/Jerusalem")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Appointment {
  id             String     @id @default(cuid())
  organizationId String
  contactId      String
  userId         String?
  startsAt       DateTime
  endsAt         DateTime
  status         ApptStatus @default(BOOKED)
  googleEventId  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([startsAt])
}

enum ApptStatus {
  BOOKED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model CalendarIntegration {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  provider       String    @default("google")
  accessToken    String
  refreshToken   String
  calendarId     String?
  expiresAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
