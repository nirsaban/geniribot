// Kesher — data model. See docs/DATA-MODEL.md for rationale.
// Every domain table carries organizationId for tenant isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Tenancy & auth ----------
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  connections   WhatsAppConnection[]
  flows         Flow[]
  contacts      Contact[]
  conversations Conversation[]
  appointments  Appointment[]
  availability  AvailabilityRule[]
  calendarLinks CalendarIntegration[]
  secrets       Secret[]
  invites       Invite[]
  leadNotes     LeadNote[]
  activities    LeadActivity[]
  broadcasts    Broadcast[]
  subscription  Subscription?
  payments      Payment[]
  messageUsage  MessageUsage[]
  onboardedAt   DateTime?
  calcomLink    String?
  /**
   * Static hosted Grow payment page (both paid plans, picked on Grow's own
   * page) — set on the platform org only, super-admin editable. Used until
   * per-org API-driven checkout (pageCode/userId/apiKey) is fully live.
   */
  growPaymentUrl String?

  /**
   * Automatic follow-up nudges for leads that went quiet. Off by default —
   * unsolicited re-engagement is a tenant decision, not platform behavior.
   */
  followUpEnabled    Boolean @default(false)
  /** How long a lead must be silent before the first/next nudge. */
  followUpAfterHours Int     @default(48)
  /** Hard cap of nudges per lead — after that a human takes over or the lead is lost. */
  followUpMax        Int     @default(2)
  /** Message template; `{name}` is replaced with the lead's name when known. */
  followUpMessage    String?
}

// Encrypted per-tenant secrets (e.g. Grow payment API keys). Values are stored
// AES-256-GCM encrypted; never returned to the client in plaintext.
model Secret {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  valueEnc       String
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  passwordHash   String
  name           String?
  role           Role     @default(AGENT)
  /**
   * Where to reach this agent on WhatsApp when the bot hands them a lead.
   * Optional — without it `notify_agent` falls back to email.
   */
  notifyPhone    String?
  isSuperAdmin   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownedContacts  Contact[]      @relation("ContactOwner")
  leadNotes      LeadNote[]
  leadActivities LeadActivity[]
  sentInvites    Invite[]       @relation("InviteSender")

  @@index([organizationId])
}

enum Role {
  OWNER
  ADMIN
  AGENT
}

/**
 * A pending teammate invitation. The raw token is shown to the inviter exactly
 * once and never stored — only its SHA-256 hash — so a database leak cannot be
 * replayed into account creation.
 */
model Invite {
  id             String    @id @default(cuid())
  organizationId String
  email          String?
  role           Role      @default(AGENT)
  tokenHash      String    @unique
  invitedById    String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InviteSender", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

enum Plan {
  FREE
  STARTER
  PRO
}

// ---------- Billing / subscriptions ----------

/**
 * A tenant's paid subscription. At most one per organization (the current one).
 * `Organization.plan` stays as the denormalized quick-read; this table is the
 * source of truth for billing period, renewal, and cancel state. Recurring
 * charges are driven by Grow's managed recurring payment page — each successful
 * charge fires our webhook, which extends `currentPeriodEnd` and records a Payment.
 */
model Subscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  plan           Plan
  status         SubscriptionStatus @default(PENDING)
  interval       BillingInterval    @default(MONTHLY)
  /** Charge amount per period, ILS, VAT-included. */
  priceIls       Int
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  /** When true the subscription lapses to FREE at period end instead of renewing. */
  cancelAtPeriodEnd  Boolean         @default(false)
  canceledAt         DateTime?
  /** Grow process/token identifiers for reconciliation (no card data stored here). */
  growProcessId  String?
  growAsmachta   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([status, currentPeriodEnd])
}

enum SubscriptionStatus {
  PENDING // created, awaiting first successful charge
  TRIALING
  ACTIVE
  PAST_DUE // a recurring charge failed; in dunning
  CANCELED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

/**
 * One Grow charge (first payment or a recurring renewal). This is the revenue
 * ledger and receipt history. Deduped by `growTransactionId` so a replayed
 * webhook cannot double-count.
 */
model Payment {
  id             String        @id @default(cuid())
  organizationId String
  subscriptionId String?
  /** Charged amount, ILS, VAT-included. */
  amountIls      Int
  status         PaymentStatus @default(PENDING)
  /** Grow transaction id — unique per real charge; the idempotency key. */
  growTransactionId String?    @unique
  growAsmachta      String?
  cardSuffix        String?
  cardBrand         String?
  /** Grow-issued invoice/receipt URL, when available. */
  invoiceUrl        String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

/**
 * Idempotency + audit log of raw provider callbacks. The webhook records the
 * event by its external id BEFORE acting; a duplicate delivery is a no-op.
 */
model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String   @default("grow")
  /** Provider's unique id for this delivery (Grow transactionId/asmachta). */
  externalId String
  payload    Json
  processedAt DateTime?
  createdAt  DateTime @default(now())

  @@unique([provider, externalId])
}

/**
 * Outbound WhatsApp message count per org per calendar month — the meter
 * behind the `monthlyMessages` plan limit. Incremented by the gateway right
 * before each send (the single choke point every producer funnels through),
 * so it's accurate regardless of whether the send came from a bot reply,
 * broadcast, reminder, or follow-up.
 */
model MessageUsage {
  id             String   @id @default(cuid())
  organizationId String
  /** Calendar month key, e.g. "2026-07". */
  yearMonth      String
  count          Int      @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, yearMonth])
}

// ---------- WhatsApp ----------
model WhatsAppConnection {
  id             String   @id @default(cuid())
  organizationId String
  label          String
  phoneNumber    String?
  provider       String   @default("baileys")
  status         WaStatus @default(PENDING)
  authState      Json?
  defaultFlowId  String?
  // Cloud API / Embedded Signup metadata (null for Baileys connections).
  wabaId             String?
  displayPhoneNumber String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum WaStatus {
  PENDING
  QR
  CONNECTED
  DISCONNECTED
  LOGGED_OUT
}

// ---------- Flows ----------
model Flow {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  version        Int      @default(1)
  isActive       Boolean  @default(false)
  definition     Json
  /**
   * The canonical set of fields this scenario collects, derived from
   * `definition` on every save: [{ key, label, expect, choices?, order }].
   *
   * Without this the field set is emergent — just whatever `field` strings the
   * builder happened to type — so the CRM cannot know a column exists until
   * some lead has filled it, cannot label it, and cannot tell a date from a
   * number. Persisting it makes the fields a fixed contract for the campaign.
   */
  fieldSchema    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ---------- Contacts / leads ----------
model Contact {
  id             String   @id @default(cuid())
  organizationId String
  phone          String
  /**
   * Full WhatsApp JID this contact messages us from. For LID ("hidden number")
   * senders `phone` holds an opaque id rather than a real number, so this is the
   * only routable address we have — outbound must prefer it.
   */
  waJid          String?
  name           String?
  fields         Json       @default("{}")
  tags           String[]   @default([])
  /** Where this lead sits in the sales pipeline. Advanced by agents, not the bot. */
  status         LeadStatus @default(NEW)
  /** The agent responsible for this lead. Null = unassigned. */
  ownerUserId    String?
  /** Name of the flow/scenario that first engaged this lead (null = just an inbound msg). */
  source         String?
  /**
   * Stable reference to that scenario. `source` is a NAME and so breaks on
   * rename; this is what the CRM resolves the field schema through.
   */
  sourceFlowId   String?
  /**
   * What the agent recorded after the sales call — written by a human in the
   * dashboard, never generated. Separate from `notes` because every lead has at
   * most one call outcome, and it is what the list view surfaces.
   */
  callSummary     String?
  callSummaryAt   DateTime?
  callSummaryById String?
  /** Last inbound/outbound WhatsApp activity — drives "stale lead" surfacing. */
  lastContactedAt DateTime?
  /**
   * Automatic follow-up bookkeeping. Deliberately separate from
   * `lastContactedAt`: a bot nudge is not "contact", and counting it as such
   * would push the lead out of the stale filter it was selected from.
   */
  followUpCount   Int       @default(0)
  lastFollowUpAt  DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner         User?          @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  appointments  Appointment[]
  notes         LeadNote[]
  activities    LeadActivity[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, ownerUserId])
  @@index([organizationId, createdAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  MEETING_SET
  WON
  LOST
}

/** Free-text notes an agent adds to a lead over time. */
model LeadNote {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String
  userId         String?
  body           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([contactId, createdAt])
}

/**
 * Append-only audit of everything that happened to a lead. This is what makes
 * handing a lead between agents work: the next person can see who did what and
 * when, rather than inferring it from the current field values.
 */
model LeadActivity {
  id             String       @id @default(cuid())
  organizationId String
  contactId      String
  /** Null = the system/bot acted, not a person. */
  userId         String?
  kind           ActivityKind
  /** Previous → new value for transitions (status, owner). Free-form by kind. */
  fromValue      String?
  toValue        String?
  meta           Json?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([contactId, createdAt])
}

enum ActivityKind {
  LEAD_CREATED
  STATUS_CHANGED
  OWNER_ASSIGNED
  NOTE_ADDED
  SUMMARY_SAVED
  TAGS_CHANGED
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  CONVERSATION_COMPLETED
  FOLLOW_UP_SENT
}

// ---------- Conversations (flow-run state) ----------
model Conversation {
  id             String      @id @default(cuid())
  organizationId String
  contactId      String
  connectionId   String
  flowId         String?
  currentNodeId  String?
  state          Json        @default("{}")
  status         ConvoStatus @default(ACTIVE)
  lastMessageAt  DateTime    @default(now())
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([organizationId])
  @@index([contactId])
}

enum ConvoStatus {
  ACTIVE
  COMPLETED
  HANDOFF
  ABANDONED
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  direction      Direction
  body           String
  raw            Json?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum Direction {
  IN
  OUT
}

// ---------- Broadcasts (initiated / scheduled outbound) ----------

/**
 * A one-off outbound campaign: one message template sent to a list of
 * recipients, immediately or at a scheduled time. Unlike conversations —
 * which a lead always initiates — a broadcast is BUSINESS-initiated.
 */
model Broadcast {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  /** Message template; `{name}` is replaced per recipient. */
  message        String
  /** Connection to send from; null = the org's first CONNECTED at send time. */
  connectionId   String?
  /** Null = send as soon as the sweep picks it up. */
  scheduledAt    DateTime?
  status         BroadcastStatus @default(SCHEDULED)
  totalCount     Int             @default(0)
  sentCount      Int             @default(0)
  failedCount    Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipients   BroadcastRecipient[]

  @@index([organizationId])
  @@index([status, scheduledAt])
}

model BroadcastRecipient {
  id          String          @id @default(cuid())
  broadcastId String
  phone       String
  name        String?
  /** Linked CRM lead when the phone matched (or was created by the import). */
  contactId   String?
  status      RecipientStatus @default(PENDING)
  error       String?
  sentAt      DateTime?

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId, status])
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
}

// ---------- Scheduling ----------
model AvailabilityRule {
  id             String  @id @default(cuid())
  organizationId String
  userId         String?
  weekday        Int
  startMinute    Int
  endMinute      Int
  slotMinutes    Int     @default(30)
  bufferMinutes  Int     @default(0)
  timezone       String  @default("Asia/Jerusalem")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Appointment {
  id             String     @id @default(cuid())
  organizationId String
  contactId      String
  userId         String?
  startsAt       DateTime
  endsAt         DateTime
  status         ApptStatus @default(BOOKED)
  googleEventId  String?
  /** Cal.com booking uid — lets cancel/reschedule webhooks find the row. */
  calcomUid      String?    @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([startsAt])
}

enum ApptStatus {
  BOOKED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model CalendarIntegration {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  provider       String    @default("google")
  accessToken    String
  refreshToken   String
  calendarId     String?
  expiresAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
